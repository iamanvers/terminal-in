# TERMINAL//IN — environment variables
# Copy to .env and fill in. Never commit .env to git.

# ── Kite Connect (only paid component, ₹2000/mo) ──────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=         # populated daily by login script

# ── NewsAPI ───────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here

# ── Security ──────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_hex

# ── Trading mode ──────────────────────────────────────────────────────────
MODE=paper                 # 'paper' or 'live'
INITIAL_CAPITAL=1000000    # ₹10,00,000
MAX_DD_PCT=0.20            # 20% drawdown circuit breaker
DAILY_LOSS_CAP_PCT=0.04    # 4% daily loss cap

# ── Optional ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata

# ── Local data paths (defaults work for single-machine use) ───────────────
# Override to move data to a different drive or shared folder.
SQLITE_PATH=./data/terminal_runtime.sqlite
DUCKDB_PATH=./data/terminal_metadata.duckdb
ARTIFACTS_DIR=./data/artifacts

# ── Cloud sync (disabled by default — local-first) ────────────────────────
CLOUD_SYNC=false
# CLOUD_BUCKET=gs://your-bucket/terminal-in  # GCS path, not used by default
